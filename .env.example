# Turso 数据库配置
# 获取方式：
#   1. 安装 Turso CLI: https://docs.turso.tech/cli
#   2. 创建数据库: turso db create food-map
#   3. 获取 URL: turso db show food-map --url
#   4. 创建 token: turso db tokens create food-map
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-auth-token

# Vercel Blob 读写 Token
# 获取方式：Vercel Dashboard → Storage → Blob → Create
# 注意：仅在部署到 Vercel 时需要；本地开发时图片上传会失败（预期行为）
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here
